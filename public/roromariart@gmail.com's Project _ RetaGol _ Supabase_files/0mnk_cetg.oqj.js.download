  .invoke('${e}', {
    body: { foo: 'bar' }
  })`}]}};var eu=e.i(211290),ep=e.i(592383),em=e.i(513826);let eh=({selectedLanguage:e,snippet:s,codeSnippets:a})=>{let{ref:i}=(0,o.useParams)(),r=(0,X.useTrack)();return(0,t.jsxs)("div",{id:s.key,className:"space-y-4 py-6",children:[(0,t.jsxs)("div",{className:"px-4 space-y-2",children:[(0,t.jsxs)("div",{className:"flex items-center justify-between",children:[(0,t.jsx)("h2",{className:"doc-heading",children:s.title}),void 0!==s.docsUrl&&(0,t.jsx)(em.DocsButton,{abbrev:!1,href:s.docsUrl})]}),void 0!==s.description&&(0,t.jsx)("div",{className:"doc-section",children:(0,t.jsx)("article",{className:"text text-sm text-foreground-light",children:(0,t.jsx)(ep.Markdown,{className:"max-w-none",content:s.description.replaceAll("[ref]",i??"_")})})})]}),a.map(s=>(0,t.jsxs)("div",{className:"px-4 space-y-2",children:[(0,t.jsx)("p",{className:"text-sm text-foreground-light",children:s.title}),(0,t.jsx)("div",{className:"codeblock-container",children:(0,t.jsx)("div",{className:"bg rounded-sm p-2",children:(0,t.jsx)(eu.SimpleCodeBlock,{className:e,onCopy:()=>{r("api_docs_code_copy_button_clicked",{title:s.title,selectedLanguage:e})},children:s[e]})})})]},s.key))]})};var eg=e.i(34231),ex=e.i(48189);let ej=({language:e,apikey:s,endpoint:a})=>{let{ref:i}=(0,o.useParams)(),r=(0,Z.useAppStateSnapshot)().activeDocsSection[1],n=(0,eg.useBucketInfoQueryPreferCached)(r,i),l=n?.allowed_mime_types,c=n?.file_size_limit;return void 0===n?null:(0,t.jsxs)("div",{className:"divide-y",children:[(0,t.jsxs)("div",{className:"space-y-1 px-4 py-4",children:[(0,t.jsxs)("div",{className:"flex items-center space-x-2",children:[(0,t.jsx)("h2",{children:n.name}),(0,t.jsx)(y.Badge,{variant:n.public?"warning":"default",children:n.public?"Public":"Private"})]}),(0,t.jsxs)("p",{className:"text-sm text-foreground-light",children:["Allowed MIME types:"," ",null===l?"All types are allowed":0===(l??[]).length?"No types are allowed":(l??[]).length>1?(l??[]).join(", "):"Unknown"]}),(0,t.jsxs)("p",{className:"text-sm 